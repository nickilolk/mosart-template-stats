# Port for the dashboard
PORT=3002

# Flat folder containing Mosart .log / .xml files — no subdirectories scanned
LOG_FOLDER=C:\MMLogs

# Path to ChannelTemplates.xml for unused template detection
CHANNEL_TEMPLATES=C:\channeltemplates\channeltemplates.xml

# Set to true if log files are on a network drive (uses polling instead of native fs events)
USE_POLLING=false

# Polling interval in ms (only relevant when USE_POLLING=true)
POLLING_INTERVAL=1000

# Folder where daily stats CSV files are written (created automatically)
# Default: stats-logs\ beside server.js
# STATS_LOG_DIR=C:\MosaartStats\logs
